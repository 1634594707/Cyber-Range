# ---- Cyber Range 环境变量配置 ----
# 复制此文件: cp env.example .env
# 修改 .env 中的值，部署脚本会读取

# 域名
DOMAIN=ctf.your-company.com

# 管理员邮箱（用于 SSL 证书通知）
ADMIN_EMAIL=admin@your-company.com

# SSH 自定义端口
SSH_PORT=22022

# CTFd 版本
CTFD_VERSION=3.7.5

# 数据盘挂载路径
DATA_DIR=/mnt/data

# ---- 数据库密码（部署时自动生成，也可手动指定） ----
# POSTGRES_PASSWORD=手动指定强密码
# REDIS_PASSWORD=手动指定强密码
# CTFD_SECRET=手动指定强密码

# ---- 可选：SMTP 邮件配置 ----
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USER=noreply@example.com
# SMTP_PASS=your-password
